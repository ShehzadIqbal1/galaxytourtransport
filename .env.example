# Public site URL — used for metadataBase, sitemap, and canonical URLs
NEXT_PUBLIC_SITE_URL=https://galaxytourtransport.com

# WhatsApp number in E.164 format (digits only after country code, no + or spaces in the value)
# Example: 971505597803
NEXT_PUBLIC_WHATSAPP_NUMBER=971505597803

# Google Analytics measurement ID (optional until analytics is enabled)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Maps API key — only required if/when a map embed is added
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
